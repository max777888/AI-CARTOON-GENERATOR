rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Generated media (frames, videos) are publicly readable
    match /projects/{projectId}/scenes/{sceneId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Character assets are publicly readable
    match /projects/{projectId}/characters/{charId}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Everything else is denied
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}