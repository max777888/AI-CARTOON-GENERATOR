    {
      "name": "CREATE-PROJECT",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Parse the JSON response\r",
              "const responseData = pm.response.json();\r",
              "\r",
              "// 2. Extract the projectId\r",
              "const projectId = responseData.projectId;\r",
              "\r",
              "// 3. Save it to an Environment Variable\r",
              "if (projectId) {\r",
              "    pm.globals.set(\"projectId\", projectId);\r",
              "    // Use 'globals' instead of 'environment'\r",
              "    console.log(\"Project ID saved: \" + projectId);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
