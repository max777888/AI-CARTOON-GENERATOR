    {
      "name": "ANALYZE_SCRIPT",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Parse the JSON response\r",
              "const responseData = pm.response.json();\r",
              "\r",
              "// 2. Check if sceneIds exists and has at least one item\r",
              "if (responseData.sceneIds && responseData.sceneIds.length > 0) {\r",
              "    // Grab the first ID in the list\r",
              "    const firstSceneId = responseData.sceneIds[0];\r",
              "    \r",
              "    // 3. Save it to your Environment Variable\r",
              "    pm.globals.set(\"sceneId\", firstSceneId);\r",
              "    console.log(\"Scene ID saved: \" + firstSceneId);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
